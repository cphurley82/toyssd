  "version": "0.2.0",
  "configurations": [
    {
      "name": "Python: Current File",
      "type": "python",
      "request": "launch",
      "program": "${file}",
      "console": "integratedTerminal",
      "justMyCode": true
    },
    {
      "name": "Python: system_test.py",
      "type": "python",
      "request": "launch",
      "module": "unittest",
      "args": [
        "${workspaceFolder}/tests/system_test.py"
      ],
      "console": "integratedTerminal",
      "justMyCode": true
    },
    {
      "name": "Python: unittest",
      "type": "python",
      "request": "launch",
      "module": "unittest",
      "args": [
        "discover",
        "-v",
        "-s",
        "./tests",
        "-p",
        "*_test.py"
      ],
      "console": "integratedTerminal",
      "justMyCode": true
    }
  ]
}